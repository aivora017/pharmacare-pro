# PharmaCare Pro — Environment Variables
# ==========================================
# Copy this file to .env and fill in your values
# IMPORTANT: NEVER commit the .env file to GitHub (it's in .gitignore)
# ==========================================

# ── App Configuration ──────────────────────────────────────────
VITE_APP_NAME="PharmaCare Pro"
VITE_APP_VERSION="1.0.0"

# ── Development ────────────────────────────────────────────────
# Set to 'true' to enable debug logging and developer tools
VITE_DEBUG=false

# ── Claude AI API (Optional) ───────────────────────────────────
# Get your API key from: https://console.anthropic.com
# Leave empty to disable cloud AI features (Tier 3)
# IMPORTANT: This is stored in the app database encrypted, NOT here
# This variable is only used during development/testing
VITE_CLAUDE_API_KEY=

# ── WhatsApp Business API (Optional) ───────────────────────────
# Get from Meta Business Suite: https://business.facebook.com
# Leave empty to disable WhatsApp integration
VITE_WHATSAPP_API_KEY=
VITE_WHATSAPP_PHONE_NUMBER_ID=

# ── Google Cloud Vision (Optional) ─────────────────────────────
# Used for handwriting OCR on prescriptions (Tier 3 AI)
# Get from: https://console.cloud.google.com
VITE_GOOGLE_VISION_API_KEY=

# ── License Server (for distribution) ─────────────────────────
# URL of your license validation server
# Can use: https://api.lemonsqueezy.com (paid) or your own server
VITE_LICENSE_SERVER_URL=https://api.lemonsqueezy.com

# ── Auto-Update Feed ───────────────────────────────────────────
# URL where Tauri checks for updates (usually your GitHub releases)
# Format: https://github.com/YOUR_USERNAME/pharmacare-pro/releases/latest/download/update-manifest.json
VITE_UPDATE_URL=

# ── Development Only ───────────────────────────────────────────
# These values are used when running in dev mode (npm run tauri dev)
# In production, the user configures these from the Settings screen
VITE_DEV_PHARMACY_NAME="Test Pharmacy"
VITE_DEV_SEED_DEMO_DATA=false
